# HEX to RGB: https://rgbcolorpicker.com/0-1
# Powder Blue: 0, 0.545, 0.843, 1
# Black: 0, 0, 0, 1
# White: 1, 1, 1, 1

<MapScreen>:
    BoxLayout:
        orientation: 'horizontal'
        # MapView takes up most of the screen width
        MapView:
            id: map_view
            zoom: 15
            lat: 34.365
            lon: -89.538
            size_hint_x: 0.75 # University, MS Coordinates

        # Side Panel layout
        BoxLayout:
            orientation: 'vertical'
            size_hint_x: 0.2 # Occupy 20% of the width
            padding: 10
            spacing: 10

            canvas.before:
                Color:
                    rgba: 0.071, 0.129, 0.259, 1 # Navy
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: "Ole Miss Parking App"
                size_hint_y: None
                height: 44
            
            Button:
                text: "Add Marker"
                background_normal: ""
                background_color: 0.816, 0.125, 0.176, 1 # Red
                # Add functionality here
            
            Button:
                text: "Zoom In"
                on_press: map_view.zoom = map_view.zoom + 1
                background_normal: ""
                background_color: 0.816, 0.125, 0.176, 1 # Red
                
            Button:
                text: "Zoom Out"
                on_press: map_view.zoom = map_view.zoom - 1
                background_normal: ""
                background_color: 0.816, 0.125, 0.176, 1 # Red

            Widget: # Spacer widget to push buttons to the top